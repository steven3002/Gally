{
  "name": "frontend-explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gen:docs": "node scripts/docs/gen.mjs",
    "predev": "node scripts/docs/gen.mjs",
    "prebuild": "node scripts/docs/gen.mjs",
    "pretest": "node scripts/docs/gen.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "NEXT_PUBLIC_DATA_SOURCE=mock playwright test",
    "test:e2e:mock": "NEXT_PUBLIC_DATA_SOURCE=mock playwright test",
    "test:e2e:live": "NEXT_PUBLIC_DATA_SOURCE=live playwright test",
    "dev:live": "NEXT_PUBLIC_DATA_SOURCE=live next dev",
    "build:live": "NEXT_PUBLIC_DATA_SOURCE=live next build",
    "start:live": "NEXT_PUBLIC_DATA_SOURCE=live next start"
  },
  "dependencies": {
    "@mysten/dapp-kit": "^1.1.1",
    "@mysten/sui": "^2.19.0",
    "@tanstack/react-query": "^5.101.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
