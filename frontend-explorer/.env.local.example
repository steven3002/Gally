# Frontend Explorer — environment toggle (FE-M8)
#
# Copy to `.env.local` and flip DATA_SOURCE to `live` to read from the Backend Indexer
# + transact through the connected wallet. Leave unset / `mock` for the offline,
# deterministic mock build (the default — the whole suite runs with no services up).

# --- Data source -----------------------------------------------------------------
# mock (default) | live
NEXT_PUBLIC_DATA_SOURCE=mock

# --- Live READ path (FE-M8a) — Backend Indexer (BI-M8) ---------------------------
# REST + WebSocket base. The WS URL is derived by swapping http→ws.
NEXT_PUBLIC_INDEXER_URL=http://127.0.0.1:8088
# Per-request timeout (ms) before a fetch is treated as "indexer unreachable".
NEXT_PUBLIC_INDEXER_TIMEOUT_MS=6000

# --- Live EXECUTION path (FE-M8b) — Sui wallet + PTBs ----------------------------
# The Sui JSON-RPC the connected wallet targets (sim soak node, then testnet).
NEXT_PUBLIC_SUI_RPC=http://127.0.0.1:9000
# Wallet network label: localnet | testnet | mainnet
NEXT_PUBLIC_SUI_NETWORK=localnet
# Deployed gally_core package id + the shared ProtocolConfig object id (required to
# build PTBs). Read these from the live-sim deploy output (sim_state.json / run_stack).
NEXT_PUBLIC_GALLY_PACKAGE_ID=
NEXT_PUBLIC_PROTOCOL_CONFIG_ID=
# USDC coin type. Defaults to `${GALLY_PACKAGE_ID}::usdc::USDC` (the SIM-D1 mock USDC).
# NEXT_PUBLIC_USDC_TYPE=
